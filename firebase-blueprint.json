{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's full name"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "manager"],
          "description": "User's role in the system"
        },
        "establishmentIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of establishment IDs the user has access to"
        },
        "posProvider": {
          "type": "string",
          "description": "Connected POS provider brand name"
        },
        "posApiKey": {
          "type": "string",
          "description": "API Key or Access Token for POS"
        },
        "posClientId": {
          "type": "string",
          "description": "Client ID/App ID for POS integration"
        },
        "posLastSyncDate": {
          "type": "string",
          "description": "Date of the last POS sync attempt"
        },
        "posLastSyncTime": {
          "type": "string",
          "description": "Time of the last POS sync attempt"
        },
        "posLastSyncStatus": {
          "type": "string",
          "enum": ["success", "failed"],
          "description": "Outcome of the last POS sync attempt"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Establishment": {
      "title": "Establishment",
      "description": "A physical location or business unit",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the establishment"
        },
        "address": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "postalCode": {
          "type": "string",
          "description": "Postal code"
        },
        "vatNumber": {
          "type": "string",
          "description": "VAT number (Numéro de TVA)"
        },
        "latitude": {
          "type": "number",
          "description": "Geographic latitude"
        },
        "longitude": {
          "type": "number",
          "description": "Geographic longitude"
        },
        "surface": {
          "type": "number",
          "description": "Surface area in square meters"
        },
        "capacity": {
          "type": "number",
          "description": "Max seating capacity"
        },
        "createdBy": {
          "type": "string",
          "description": "UID of the user who created the establishment"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "createdAt", "createdBy"]
    },
    "Revenue": {
      "title": "Revenue",
      "description": "Daily revenue entry for an establishment",
      "type": "object",
      "properties": {
        "establishmentId": {
          "type": "string",
          "description": "ID of the establishment"
        },
        "date": {
          "type": "string",
          "description": "Date of the revenue entry (YYYY-MM-DD)"
        },
        "payments": {
          "type": "object",
          "properties": {
            "cb": { "type": "number" },
            "cbContactless": { "type": "number" },
            "cash": { "type": "number" },
            "amex": { "type": "number" },
            "amexContactless": { "type": "number" },
            "tr": { "type": "number" },
            "trContactless": { "type": "number" },
            "transfer": { "type": "number" }
          },
          "required": ["cb", "cbContactless", "cash", "amex", "amexContactless", "tr", "trContactless", "transfer"]
        },
        "total": {
          "type": "number",
          "description": "Total revenue for the day"
        },
        "notes": {
          "type": "string",
          "description": "Optional notes for the revenue entry"
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Optional attachments for the revenue entry"
        },
        "createdBy": {
          "type": "string",
          "description": "UID of the user who created the entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["establishmentId", "date", "payments", "total", "createdBy", "createdAt", "updatedAt"]
    },
    "AlertRule": {
      "title": "AlertRule",
      "description": "Custom alert rule for revenue or payment methods",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who created the alert"
        },
        "name": {
          "type": "string",
          "description": "Name of the alert"
        },
        "establishmentId": {
          "type": "string",
          "description": "ID of the establishment or 'all'"
        },
        "type": {
          "type": "string",
          "enum": ["revenue_drop", "payment_method_change", "pos_consecutive_failures"],
          "description": "Type of the alert"
        },
        "threshold": {
          "number": 165,
          "description": "Threshold value for the alert",
          "type": "number"
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment method to monitor (if type is payment_method_change)"
        },
        "timeframe": {
          "type": "string",
          "enum": ["daily", "weekly", "monthly"],
          "description": "Timeframe to evaluate the alert"
        },
        "notifyEmail": {
          "type": "boolean",
          "description": "Whether to notify via email"
        },
        "emailAddress": {
          "type": "string",
          "description": "Email address for notifications"
        },
        "notifySms": {
          "type": "boolean",
          "description": "Whether to notify via SMS"
        },
        "phoneNumber": {
          "type": "string",
          "description": "Phone number for SMS notifications"
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the alert is active"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "name", "establishmentId", "type", "threshold", "timeframe", "isActive", "createdAt"]
    },
    "Cost": {
      "title": "Cost",
      "description": "Monthly costs for an establishment to calculate prime cost and margin",
      "type": "object",
      "properties": {
        "establishmentId": {
          "type": "string",
          "description": "ID of the establishment"
        },
        "month": {
          "type": "string",
          "description": "Month of the cost entry (YYYY-MM)"
        },
        "laborCost": {
          "type": "number",
          "description": "Total labor costs for the month"
        },
        "cogs": {
          "type": "number",
          "description": "Cost of Goods Sold (raw materials)"
        },
        "rent": {
          "type": "number"
        },
        "utilities": {
          "type": "number"
        },
        "bankLoan": {
          "type": "number"
        },
        "taxes": {
          "type": "number"
        },
        "vat": {
          "type": "number"
        },
        "otherCosts": {
          "type": "number",
          "description": "Other fixed or variable costs"
        },
        "createdBy": {
          "type": "string",
          "description": "UID of the user who created the entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["establishmentId", "month", "laborCost", "cogs", "createdBy", "createdAt", "updatedAt"]
    },
    "POSSyncLog": {
      "title": "POSSyncLog",
      "description": "Logs tracking each Smart Sync synchronization run or attempt",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the user who triggered the sync"
        },
        "establishmentId": {
          "type": "string",
          "description": "ID of the establishmentSynced or 'all' if calculated globally"
        },
        "posProvider": {
          "type": "string",
          "description": "The name of the connected POS brand"
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed"],
          "description": "Outcome of the synchronization run"
        },
        "errorMessage": {
          "type": "string",
          "description": "Detailed developer error message if the attempt failed"
        },
        "service": {
          "type": "string",
          "description": "The service target that was synced (midi, soir or none)"
        },
        "totalSynced": {
          "type": "number",
          "description": "Total revenue registered or imported in EUR"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Exact point in time of the synchronization trigger"
        }
      },
      "required": ["userId", "posProvider", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "/establishments/{establishmentId}": {
      "schema": {
        "$ref": "#/entities/Establishment"
      },
      "description": "Establishments"
    },
    "/revenues/{revenueId}": {
      "schema": {
        "$ref": "#/entities/Revenue"
      },
      "description": "Daily revenue entries"
    },
    "/alerts/{alertId}": {
      "schema": {
        "$ref": "#/entities/AlertRule"
      },
      "description": "Custom alert rules"
    },
    "/costs/{costId}": {
      "schema": {
        "$ref": "#/entities/Cost"
      },
      "description": "Monthly cost records"
    },
    "/pos_sync_logs/{logId}": {
      "schema": {
        "$ref": "#/entities/POSSyncLog"
      },
      "description": "Smart Sync attempts history log logs"
    }
  }
}
